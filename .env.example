# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Pexels API Key (for copyright-free stock video B-rolls)
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Voiceover TTS Provider Configuration
# Supported options: 'edge' (free, no key needed) or 'elevenlabs' (premium, requires key)
TTS_PROVIDER=edge
VOICEOVER_LOCALE=en-IN-NeerjaNeural

# ElevenLabs configuration (only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# YouTube OAuth2 Credentials
# Set these up in Google Cloud Console with YouTube Data API v3 enabled.
YT_CLIENT_ID=your_client_id_here
YT_CLIENT_SECRET=your_client_secret_here
YT_REFRESH_TOKEN=your_refresh_token_here
